# ─── Python 缓存 ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
*.egg-info/
dist/
build/

# ─── 虚拟环境 ──────────────────────────────────────────────────────────────
.venv/
venv/
env/
.env/

# ─── IDE / 编辑器 ──────────────────────────────────────────────────────────
.vscode/
.cursor/
.idea/
*.swp
*.swo

# ─── Git ───────────────────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ─── 机密文件（绝对不能进镜像，运行时通过 env_file 或环境变量注入）────────
.env
.envrc

# ─── 本地数据（通过 volume mount 挂载，不进镜像避免 image 体积膨胀）────────
storage/
logs/
runs/
mlflow_artifacts/
mlflow.db

# ─── 大型模型文件（通过 volume mount 挂载）────────────────────────────────
models/*.pt
models/*.onnx
models/*.engine
models/*.weights

# ─── 文档 / 开发文件 ──────────────────────────────────────────────────────
docs/
*.md
CHANGELOG*
README*
ROOT_LAYOUT*

# ─── 测试 ──────────────────────────────────────────────────────────────────
tests/
.coverage
htmlcov/

# ─── 数据库文件（由 postgres 容器托管，本地 .db 不进镜像）─────────────────
*.db
db/

# ─── macOS 系统文件 ────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
