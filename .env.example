############################################
# DataFactory 本地环境变量示例文件
# 复制为 `.env` 后填写真实值；`.env` 请勿提交到 Git。
############################################

# 邮箱授权码（例如 iCloud / Gmail 的 app-specific password）
EMAIL_PASSWORD=

# 本地 CVAT（main.py --auto-cvat 时使用）
# CVAT_LOCAL_URL=http://localhost:8080
# CVAT_LOCAL_USERNAME=admin
# CVAT_LOCAL_PASSWORD=xxx

# PostgreSQL（必填；docker compose up -d 启动后填写）
DATABASE_URL=postgresql://datafactory:datafactory@localhost:5432/datafactory
MLFLOW_BACKEND_URI=postgresql://datafactory:datafactory@localhost:5432/mlflow
